# Backend Environment Variables
JWT_SECRET=supersecretjwtkey_change_in_production
PORT=5000
MONGODB_URI=mongodb://localhost:27017/intellicar
AI_SERVICE_URL=http://localhost:8000

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
