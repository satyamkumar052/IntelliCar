# Email / Nodemailer
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Frontend
VITE_API_URL=http://localhost:5000/api
